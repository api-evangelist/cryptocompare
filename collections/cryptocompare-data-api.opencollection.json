          "http": {
            "method": "GET",
            "url": "https://data-api.cryptocompare.com/spot/v1/latest/orderbook/l1/top",
            "params": [
              {
                "name": "market",
                "value": "",
                "type": "query",
                "description": "Spot or derivatives market (e.g. coinbase, kraken, binance, bitstamp, ccix)."
              },
              {
                "name": "instruments",
                "value": "",
                "type": "query",
                "description": "Comma-separated instrument identifiers (e.g. BTC-USD,ETH-USD)."
              }
            ]
          },
          "docs": "Returns the top of the order book (best bid and best ask) for one or more spot instruments. Updated continuously."
        }
